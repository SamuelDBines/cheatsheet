{% extends "layouts/base.njk" %}

{% set pageTitle = "Home" %}

{% block content %}
  <section class="hero">
    <h1>{{ site.title }}</h1>
    <p>{{ site.tagline }}</p>
  </section>

  <section class="toc">
    <h2>Sections</h2>
    <ul>
      {% for section in cheats.sections %}
        <li><a href="./{{ section.id }}.html">{{ section.title }}</a></li>
      {% endfor %}
    </ul>
  </section>
{% endblock %}

<section class="cheat-section" id="{{ section.id }}">
  <h2>{{ section.title }}</h2>

  <div class="cheat-grid">
    {% for item in section.items %}
      <article class="cheat-card">
        <header class="cheat-card__header">
          <h3>{{ item.title }}</h3>
          <div class="cheat-card__meta">
            {% if item.kind == "doc" %}
              <code>docs</code>
            {% else %}
              <code>{{ item.lang }}</code>
            {% endif %}
          </div>
        </header>

        <div class="cheat-card__body">
          {% if item.kind == "doc" %}
            <p class="doc-desc">{{ item.description }}</p>
            <p class="doc-link">
              <a href="{{ item.url }}" target="_blank" rel="noreferrer">{{ item.url }}</a>
            </p>
          {% else %}
            <pre><code class="language-{{ item.lang }}">{{ item.code | escape }}</code></pre>
          {% endif %}
        </div>
      </article>
    {% endfor %}
  </div>
</section>

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <title>{% if pageTitle %}{{ pageTitle }} · {% endif %}{{ site.title }}</title>

    <link rel="stylesheet" href="https://bareframe.org/versions/0.1.3/themes/system.css" />
    <link rel="stylesheet" href="./assets/styles.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/highlight.js@11.11.1/styles/github.min.css" media="(prefers-color-scheme: light)" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/highlight.js@11.11.1/styles/github-dark.min.css" media="(prefers-color-scheme: dark)" />
  </head>

  <body>
    <header class="site-header">
      <div class="container">
        <div class="site-title">
          <a href="./index.html">{{ site.title }}</a>
          <span class="site-tagline">{{ site.tagline }}</span>
        </div>

        <nav class="site-nav" aria-label="Primary">
          <a href="./index.html">Home</a>
          {% for section in cheats.sections %}
            <a href="./{{ section.id }}.html">{{ section.title }}</a>
          {% endfor %}
        </nav>
      </div>
    </header>

    <main class="container">
      {% block content %}{% endblock %}
    </main>

    <footer class="site-footer">
      <div class="container">
        <small>Built from Nunchucks templates into <code>public/</code>.</small>
      </div>
    </footer>

    <script src="https://bareframe.org/versions/0.1.3/bareframe.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/highlight.js@11.11.1/highlight.min.js"></script>
    <script type="module" src="./assets/site.js"></script>
  </body>
</html>
